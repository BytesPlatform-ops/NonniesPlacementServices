# SMTP for website form submissions (Google Workspace).
# Copy to `.env` (or `.env.local`) and fill in a real Gmail App Password.
# NEVER commit real credentials — .env and .env*.local are gitignored.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=admin@nonnisplacement.com
SMTP_PASS=GOOGLE_APP_PASSWORD_HERE
FORM_TO=admin@nonnisplacement.com
